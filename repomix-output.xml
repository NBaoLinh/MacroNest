                    .take()
                    .map(|session| (session.preset_id, session.events))
            } else {
                *guard = Some(MouseRecordingSession {
                    preset_id,
                    last_event_at: Instant::now(),
                    events: Vec::new(),
                    dirty: true,
                });
                None
            }
        };

        let ui_tx = HOOK_STATE.lock().ui_tx.clone();

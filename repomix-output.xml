                            .spacing([6.0, 6.0])
                            .show(ui, |ui| {
                                let mut item_index = 0usize;

                                for (base_action, down_action, up_action, popup_key) in
                                    Self::mouse_click_action_groups().iter().copied()
                                {
                                    Self::render_mouse_click_action_group_option(
                                        ui,
                                        language,
                                        id_source,
                                        current,
                                        live_sync,
                                        base_action,
                                        down_action,
                                        up_action,
                                        popup_key,

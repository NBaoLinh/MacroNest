            }

            let copy_enabled = !self.selected_macro_groups.is_empty();
            if ui
                .add_enabled(
                    copy_enabled,
                    Button::new(Self::tr_lang(language, "Copy", "Copy"))
                        .min_size(egui::vec2(112.0, 24.0)),
                )
                .clicked()
            {
                self.copy_selected_macro_groups();

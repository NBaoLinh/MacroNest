                                    item_index += 1;

                                    if item_index % 6 == 0 {
                                        ui.end_row();
                                    }
                                }

                                for action in Self::mouse_leaf_action_groups().iter().copied() {
                                    let leaf_response = Self::render_macro_action_button(
                                        ui,

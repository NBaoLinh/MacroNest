    fn versions_are_equal(v1: &str, v2: &str) -> bool {
        let mut parts1: Vec<u32> = v1
            .split('.')
            .map(|s| s.parse::<u32>().unwrap_or(0))
            .collect();
        let mut parts2: Vec<u32> = v2
            .split('.')
            .map(|s| s.parse::<u32>().unwrap_or(0))
            .collect();
        while parts1.last() == Some(&0) {
            parts1.pop();
        }
        while parts2.last() == Some(&0) {
            parts2.pop();
        }
        parts1 == parts2
    }


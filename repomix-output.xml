                    [340.0, 20.0],
                    DragValue::new(&mut style.horizontal_length)
                        .range(0.0..=80.0)
                        .speed(0.1),
                );
                changed |= response.changed();
                dragging |= response.dragged();
                ui.end_row();

                ui.label(Self::tr_lang(
                    language,
                    "Vertical length",
                    "Vertical length",
                ));
                let response = ui.add_sized(
                    [340.0, 20.0],
                    DragValue::new(&mut style.vertical_length)
                        .range(0.0..=80.0)
                        .speed(0.1),
                );

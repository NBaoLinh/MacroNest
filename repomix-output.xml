    fn show_preset_card<R>(
        ui: &mut egui::Ui,
        enabled: bool,
        add_contents: impl FnOnce(&mut egui::Ui) -> R,
    ) -> R {
        let dark_mode = ui.visuals().dark_mode;
        Self::preset_frame(ui, enabled)
            .show(ui, |ui| {
                let previous = ui.visuals().override_text_color;
                if dark_mode {

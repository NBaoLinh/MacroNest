    impl ActiveTimerState {
        fn get_elapsed_ms(&self) -> u64 {
            if self.running {
                if let Some(start) = self.start_time {
                    self.elapsed_ms + start.elapsed().as_millis() as u64
                } else {
                    self.elapsed_ms
                }
            } else {
                self.elapsed_ms
            }
        }
    }

